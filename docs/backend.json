
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the Tawasul social media application.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "followingIds": { "type": "array", "items": { "type": "string" } },
        "followerIds": { "type": "array", "items": { "type": "string" } },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "username", "createdAt"]
    },
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "description": "Represents a user post.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" }
      },
      "required": ["id", "authorId", "content", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "content", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "follow", "mention", "comment"] },
        "fromUserId": { "type": "string" },
        "fromUsername": { "type": "string" },
        "fromAvatar": { "type": "string" },
        "postId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "users/{userId}", "definition": { "entityName": "User" } },
      { "path": "users/{userId}/notifications/{notifId}", "definition": { "entityName": "Notification" } },
      { "path": "users/{userId}/bookmarks/{postId}", "definition": { "entityName": "Post" } },
      { "path": "posts/{postId}", "definition": { "entityName": "Post" } },
      { "path": "posts/{postId}/likes/{userId}", "definition": { "entityName": "Like" } },
      { "path": "posts/{postId}/comments/{commentId}", "definition": { "entityName": "Comment" } }
    ]
  }
}
