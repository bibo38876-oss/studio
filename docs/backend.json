
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user profile in Timgad.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "verificationType": { "type": "string", "enum": ["none", "blue", "gold"] },
        "coins": { "type": "number", "default": 0 },
        "isPrivate": { "type": "boolean", "default": false },
        "followingIds": { "type": "array", "items": { "type": "string" } },
        "followerIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Ad": {
      "title": "Ad",
      "type": "object",
      "description": "Represents a user story ad.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "title": { "type": "string" },
        "link": { "type": "string" },
        "imageUrl": { "type": "string" },
        "remainingClicks": { "type": "number", "default": 100 }
      }
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "description": "Represents a social post.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "reportsCount": { "type": "number", "default": 0 },
        "promoted": { "type": "boolean", "default": false }
      }
    },
    "WithdrawalRequest": {
      "title": "WithdrawalRequest",
      "type": "object",
      "description": "Represents a TRX withdrawal request.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "finalTRX": { "type": "number" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] }
      }
    }
  }
}
