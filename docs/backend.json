
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the Timgad social media application.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "bannerUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLoginAt": { "type": "string", "format": "date-time" },
        "lastPollCreatedAt": { "type": "string", "format": "date-time" },
        "followingIds": { "type": "array", "items": { "type": "string" } },
        "followerIds": { "type": "array", "items": { "type": "string" } },
        "interactedAuthorIds": { "type": "array", "items": { "type": "string" } },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "verificationType": { "type": "string", "enum": ["none", "blue", "gold"] },
        "isPrivate": { "type": "boolean", "default": false },
        "coins": { "type": "number", "default": 0 }
      },
      "required": ["id", "username", "createdAt"]
    },
    "Ad": {
      "title": "Ad",
      "type": "object",
      "description": "Represents a story advertisement.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "link": { "type": "string", "format": "uri" },
        "totalClicks": { "type": "number", "default": 100 },
        "remainingClicks": { "type": "number", "default": 100 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "title", "imageUrl", "link"]
    },
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "description": "Represents a user post in Timgad.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrls": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number", "default": 0 },
        "commentsCount": { "type": "number", "default": 0 },
        "promoted": { "type": "boolean" },
        "authorVerificationType": { "type": "string" }
      },
      "required": ["id", "authorId", "content", "createdAt"]
    }
  }
}
