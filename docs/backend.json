
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the Timgad social media application.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "bannerUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastPollCreatedAt": { "type": "string", "format": "date-time", "description": "Timestamp of the last poll created by the user." },
        "followingIds": { "type": "array", "items": { "type": "string" } },
        "followerIds": { "type": "array", "items": { "type": "string" } },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "verificationType": { "type": "string", "enum": ["none", "blue", "gold"] },
        "isPrivate": { "type": "boolean", "default": false }
      },
      "required": ["id", "username", "createdAt"]
    },
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "description": "Represents a user post in Timgad, potentially including a poll.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrls": { "type": "array", "items": { "type": "string" } },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "poll": {
          "type": "object",
          "properties": {
            "question": { "type": "string" },
            "options": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "text": { "type": "string" },
                  "votes": { "type": "number", "default": 0 }
                }
              }
            },
            "totalVotes": { "type": "number", "default": 0 },
            "expiresAt": { "type": "string", "format": "date-time" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "repostsCount": { "type": "number" },
        "viewsCount": { "type": "number" }
      },
      "required": ["id", "authorId", "content", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "users/{userId}", "definition": { "entityName": "User" } },
      { "path": "posts/{postId}", "definition": { "entityName": "Post" } },
      { "path": "posts/{postId}/pollVotes/{userId}", "description": "Stores individual user votes for a poll." }
    ]
  }
}
