
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the Tawasul social media application.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "followingIds": { "type": "array", "items": { "type": "string" } },
        "followerIds": { "type": "array", "items": { "type": "string" } },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "username", "createdAt"]
    },
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "description": "Represents a user post.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaUrls": { "type": "array", "items": { "type": "string" } },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" }
      },
      "required": ["id", "authorId", "content", "createdAt"]
    },
    "Group": {
      "title": "Group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "membersCount": { "type": "number" }
      },
      "required": ["name", "creatorId", "createdAt"]
    },
    "GroupMessage": {
      "title": "GroupMessage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "content", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "users/{userId}", "definition": { "entityName": "User" } },
      { "path": "posts/{postId}", "definition": { "entityName": "Post" } },
      { "path": "groups/{groupId}", "definition": { "entityName": "Group" } },
      { "path": "groups/{groupId}/messages/{messageId}", "definition": { "entityName": "GroupMessage" } }
    ],
    "indexes": [
      {
        "collectionGroup": "posts",
        "queryScope": "COLLECTION",
        "fields": [
          { "fieldPath": "authorId", "order": "ASCENDING" },
          { "fieldPath": "createdAt", "order": "DESCENDING" }
        ],
        "description": "Required for Profile page posts sorting."
      },
      {
        "collectionGroup": "posts",
        "queryScope": "COLLECTION",
        "fields": [
          { "fieldPath": "authorId", "arrayConfig": "CONTAINS" },
          { "fieldPath": "createdAt", "order": "DESCENDING" }
        ],
        "description": "Alternative for following feed (using array-contains if applicable, or IN operator which requires similar composite index)."
      }
    ]
  }
}
