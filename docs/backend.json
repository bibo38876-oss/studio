
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the Tawasul social media application.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "followingIds": { "type": "array", "items": { "type": "string" } },
        "followerIds": { "type": "array", "items": { "type": "string" } },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "username", "createdAt"]
    },
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "description": "Represents a user post.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrls": { "type": "array", "items": { "type": "string" } },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "repostsCount": { "type": "number" }
      },
      "required": ["id", "authorId", "content", "createdAt"]
    },
    "Repost": {
      "title": "Repost",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "repostedAt": { "type": "string", "format": "date-time" },
        "originalAuthorId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "users/{userId}", "definition": { "entityName": "User" } },
      { "path": "users/{userId}/reposts/{postId}", "definition": { "entityName": "Repost" } },
      { "path": "posts/{postId}", "definition": { "entityName": "Post" } }
    ],
    "indexes": [
      {
        "collectionGroup": "posts",
        "queryScope": "COLLECTION",
        "fields": [
          { "fieldPath": "authorId", "order": "ASCENDING" },
          { "fieldPath": "createdAt", "order": "DESCENDING" }
        ]
      }
    ]
  }
}
