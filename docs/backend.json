
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the Tawasul social media application.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "bannerUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "followingIds": { "type": "array", "items": { "type": "string" } },
        "followerIds": { "type": "array", "items": { "type": "string" } },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "verificationType": { "type": "string", "enum": ["none", "blue", "gold"] },
        "isPrivate": { "type": "boolean", "default": false, "description": "Whether the user profile is private." }
      },
      "required": ["id", "username", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "follow", "repost"] },
        "fromUserId": { "type": "string" },
        "fromUsername": { "type": "string" },
        "fromAvatar": { "type": "string" },
        "postId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      }
    },
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "description": "Represents a user post.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrls": { "type": "array", "items": { "type": "string" } },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "repostsCount": { "type": "number" },
        "viewsCount": { "type": "number" }
      },
      "required": ["id", "authorId", "content", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "users/{userId}", "definition": { "entityName": "User" } },
      { "path": "users/{userId}/notifications/{notifId}", "definition": { "entityName": "Notification" } },
      { "path": "posts/{postId}", "definition": { "entityName": "Post" } }
    ]
  }
}
