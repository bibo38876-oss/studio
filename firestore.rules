
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // وظائف مساعدة للتحقق من الهوية
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // قواعد بيانات المستخدمين والملفات الشخصية
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }
      
      match /bookmarks/{postId} {
        allow read, write: if isOwner(userId);
      }

      match /following/{followedId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      match /followers/{followerId} {
        allow read: if true;
        allow create: if isOwner(followerId);
        allow delete: if isOwner(followerId) || isOwner(userId);
      }
    }

    // قواعد المنشورات - القراءة عامة للجميع بشكل مؤكد وصريح
    // تحديث إجباري لحل مشكلة "Missing or insufficient permissions" في الملف الشخصي
    // تاريخ التحديث: 2024-05-22 10:45 AM
    match /posts/{postId} {
      allow read: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      match /likes/{likingUserId} {
        allow read: if true;
        allow write: if isOwner(likingUserId);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid);
      }
    }
  }
}
