
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'adelbenmaza8@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    match /ads/{adId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /adClicks/{clickId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !exists(/databases/$(database)/documents/adClicks/$(clickId));
    }

    match /withdrawal_requests/{reqId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isOwner(resource.data.authorId) || 
        isAdmin() || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount', 'likesCount', 'repostsCount', 'commentsCount', 'bookmarksCount', 'poll', 'reportsCount', 'impressions_left', 'promoted'])
      );
      allow delete: if isSignedIn() && (isOwner(resource.data.authorId) || isAdmin());

      match /likes/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      match /comments/{commentId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn() && (isOwner(resource.data.authorId) || isAdmin());
      }

      match /pollVotes/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
      
      match /notifications/{notifId} {
        allow create: if isSignedIn();
        allow read, update, delete: if isOwner(userId) || isAdmin();
      }

      match /following/{targetId} {
        allow read, write: if isOwner(userId);
      }

      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
      
      match /bookmarks/{postId} {
        allow read, write: if isOwner(userId);
      }

      match /likedPosts/{postId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      match /supportedPeople/{targetUserId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      match /supporters/{targetUserId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    match /vault/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      match /participants/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }
  }
}
